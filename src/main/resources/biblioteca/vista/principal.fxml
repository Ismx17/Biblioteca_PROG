<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="750.0" prefWidth="1050.0" spacing="10.0" stylesheets="@estilos.css"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="biblioteca.controlador.MainController">

    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Label text="Gestión Biblioteca IES Al-Ándalus">
        <font> <Font name="System Bold" size="24.0" /> </font>
        <VBox.margin> <Insets left="20.0" top="10.0" /> </VBox.margin>
    </Label>

    <TabPane prefHeight="700.0" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
        <tabs>
            <Tab text="Libros">
                <SplitPane dividerPositions="0.65">
                    <VBox spacing="10.0">
                        <padding>
                            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                        </padding>
                        <TableView fx:id="tvLibros" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colIsbn" prefWidth="110" text="ISBN" />
                                <TableColumn fx:id="colTitulo" prefWidth="200" text="Título" />
                                <TableColumn fx:id="colCategoria" prefWidth="90" text="Categoría" />
                                <TableColumn fx:id="colAnio" prefWidth="60" text="Año" />
                                <TableColumn fx:id="colInfoExtra" prefWidth="120" text="Detalles" />
                            </columns>
                        </TableView>
                        <Button onAction="#handleEliminarLibro" styleClass="btn-eliminar" text="Eliminar Libro" />
                    </VBox>

                    <ScrollPane fitToWidth="true">
                        <VBox spacing="10.0">
                            <padding>
                                <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                            </padding>
                            <Label text="Nuevo Registro" style="-fx-font-weight: bold; -fx-font-size: 14;" />
                            <TextField fx:id="tfIsbn" promptText="ISBN (13 dígitos)" />
                            <TextField fx:id="tfTitulo" promptText="Título" />
                            <TextField fx:id="tfAnio" promptText="Año" />
                            <ComboBox fx:id="cbCategoria" maxWidth="Infinity" promptText="Categoría" />
                            <Separator />
                            <Label text="Autor/es" style="-fx-font-weight: bold;" />
                            <HBox spacing="5.0">
                                <TextField fx:id="tfNombreAutor" prefWidth="80" promptText="Nombre" />
                                <TextField fx:id="tfApellidosAutor" prefWidth="100" promptText="Apellidos" />
                                <TextField fx:id="tfNacionalidadAutor" prefWidth="50" promptText="Nac." />
                                <Button onAction="#handleAgregarAutorALista" text="+" />
                            </HBox>
                            <ListView fx:id="lvAutoresTemporales" prefHeight="80.0" />
                            <CheckBox fx:id="chbEsAudiolibro" onAction="#handleCheckAudiolibro" text="¿Es Audiolibro?" />
                            <VBox fx:id="vbCamposAudiolibro" managed="false" spacing="10.0" visible="false">
                                <TextField fx:id="tfDuracion" promptText="Segundos" />
                                <ComboBox fx:id="cbFormato" maxWidth="Infinity" promptText="Formato Audio" />
                            </VBox>
                            <Button maxWidth="Infinity" onAction="#handleAltaLibro" styleClass="btn-guardar" text="Guardar Libro" />
                        </VBox>
                    </ScrollPane>
                </SplitPane>
            </Tab>

            <Tab text="Usuarios">
                <SplitPane dividerPositions="0.65">
                    <VBox spacing="10.0">
                        <padding>
                            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                        </padding>
                        <TableView fx:id="tvUsuarios" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colDni" prefWidth="100" text="DNI" />
                                <TableColumn fx:id="colNombreUsuario" prefWidth="200" text="Nombre" />
                                <TableColumn fx:id="colEmail" prefWidth="200" text="Email" />
                            </columns>
                        </TableView>
                        <Button onAction="#handleEliminarUsuario" styleClass="btn-eliminar" text="Eliminar Usuario" />
                    </VBox>

                    <VBox spacing="10.0">
                        <padding>
                            <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                        </padding>
                        <Label text="Nuevo Usuario" style="-fx-font-weight: bold; -fx-font-size: 14;" />
                        <TextField fx:id="tfDni" promptText="DNI (8 números + Letra)" />
                        <TextField fx:id="tfNombreUsuario" promptText="Nombre completo" />
                        <TextField fx:id="tfEmail" promptText="Email" />
                        <Separator />
                        <Label text="Dirección" style="-fx-font-weight: bold;" />
                        <TextField fx:id="tfVia" promptText="Vía" />
                        <HBox spacing="5.0">
                            <TextField fx:id="tfNumero" prefWidth="60" promptText="Nº" />
                            <TextField fx:id="tfCp" promptText="C.P." HBox.hgrow="ALWAYS" />
                        </HBox>
                        <TextField fx:id="tfLocalidad" promptText="Localidad" />
                        <Button maxWidth="Infinity" onAction="#handleAltaUsuario" styleClass="btn-registrar" text="Registrar Usuario" />
                    </VBox>
                </SplitPane>
            </Tab>

            <Tab text="Préstamos">
                <SplitPane dividerPositions="0.65">
                    <VBox spacing="10.0">
                        <padding>
                            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                        </padding>
                        <TableView fx:id="tvPrestamos" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colPrestamoLibro" prefWidth="200" text="Libro" />
                                <TableColumn fx:id="colPrestamoUsuario" prefWidth="150" text="Usuario" />
                                <TableColumn fx:id="colFInicio" prefWidth="100" text="Inicio" />
                                <TableColumn fx:id="colFLimite" prefWidth="100" text="Límite" />
                                <TableColumn fx:id="colEstado" prefWidth="150" text="Estado" />
                            </columns>
                        </TableView>
                        <Button onAction="#handleDevolverPrestamo" styleClass="btn-devolver" text="Marcar Devuelto" />
                    </VBox>

                    <VBox spacing="15.0">
                        <padding>
                            <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                        </padding>
                        <Label text="Nuevo Préstamo" style="-fx-font-weight: bold; -fx-font-size: 14;" />
                        <ComboBox fx:id="cbLibrosPrestamo" maxWidth="Infinity" promptText="Libro" />
                        <ComboBox fx:id="cbUsuariosPrestamo" maxWidth="Infinity" promptText="Usuario" />
                        <DatePicker fx:id="dpFechaPrestamo" maxWidth="Infinity" promptText="Fecha Inicio" />
                        <Button maxWidth="Infinity" onAction="#handleNuevoPrestamo" prefHeight="50.0" styleClass="btn-prestar" text="Prestar" />
                    </VBox>
                </SplitPane>
            </Tab>
        </tabs>
    </TabPane>
</VBox>